{% extends 'base.html.twig' %}

{% block title %}PDF-GEN - Accueil{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

        .home-content-container {
            text-align: center;
            padding: 3rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        .progress-section {
            padding: 1.5rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.875rem;
            border-bottom: 1px solid #000000;
            flex-wrap: wrap;
            gap: 1.5rem;
            background-color: var(--bg-color);
        }

        .progress-bar-container {
            flex: 1;
            margin: 0 2.5rem;
            min-width: 250px;
        }

        .progress-text {
            margin-bottom: 0.5rem;
            white-space: nowrap;
            font-weight: 500;
            font-size: 0.813rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #4A5568;
        }

        .progress-bar {
            width: 100%;
            height: 10px;
            background-color: #E2E8F0;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.06);
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--dark-color) 0%, #1a1a1a 100%);
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        .plan-info {
            text-align: right;
            font-weight: 600;
            color: #2D3748;
        }

        .plan-info div:last-child {
            font-size: 0.75rem;
            font-weight: 400;
            color: #718096;
            margin-top: 0.25rem;
        }

        .main-title {
            font-size: 4rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.1;
        }

        .subtitle {
            font-size: 1.25rem;
            margin-bottom: 4rem;
            font-weight: 400;
            color: #4A5568;
            letter-spacing: 0.3px;
        }

        .pdf-options {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 2rem;
            margin-bottom: 4rem;
            padding: 0 2rem;
        }

        .pdf-option {
            position: relative;
            background: #FFFFFF;
            border-radius: 16px;
            padding: 2.5rem 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            border: 1px solid #EAEAEA;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }

        .pdf-option:not(.disabled):hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.07);
            border-color: #DDDDDD;
        }

        .pdf-option.disabled {
            opacity: 0.6;
            background-color: #f1f1f1;
            cursor: not-allowed;
        }

        .pdf-option-icon {
            font-size: 28px;
            color: var(--dark-color);
            margin-bottom: 1.25rem;
        }

        .pdf-option h3 {
            margin: 0 0 0.5rem 0;
            font-size: 1.1rem;
            font-weight: 600;
            color: #2D3748;
        }

        .pdf-option-description {
            font-size: 0.9rem;
            color: #718096;
            line-height: 1.6;
        }

        .pdf-option-plans {
            position: absolute;
            top: 1rem;
            right: 1rem;
            display: flex;
            gap: 0.4rem;
        }

        .plan-tag {
            padding: 0.25rem 0.5rem;
            font-size: 0.80rem;
            font-weight: 800;
            border: 2px solid black;
            text-transform: uppercase;
        }

        .plan-tag.starter { background-color: #F4E04D; }
        .plan-tag.pro { background-color: #FF6B6B; }
        .plan-tag.elite { background-color: #4ECDC4; }
        .plan-tag.legend { background-color: #C792EA; }
    </style>
{% endblock %}

{% block body %}
    {% if app.user and app.user.plan %}
        <div class="progress-section">
            <div class="progress-text">Générations disponibles</div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: {{ ((app.user.generationsUsed / app.user.plan.limitGeneration) * 100)|round }}%;"></div>
                </div>
            </div>
            <div style="font-weight: 600; color: #2D3748;">{{ app.user.plan.limitGeneration - app.user.generationsUsed }} / {{ app.user.plan.limitGeneration }} restants</div>
            <div class="plan-info">
                <div>Plan actuel : {{ app.user.plan.name|upper }}</div>
            </div>
        </div>
    {% endif %}

    <div class="home-content-container">
        <h1 class="main-title">CONVERTISSEUR PDF</h1>
        <p class="subtitle">Convertissez et modifiez instantanément tout type de document !</p>

        <div class="pdf-options" id="options-container">
            {% for tool in tools %}
                {% set has_access = app.user and can_user_use_tool(app.user, tool) %}
                <div class="pdf-option {% if not has_access %}disabled{% endif %}" id="tool-card-{{ tool.routeParam }}" onclick="loadTool('{{ tool.routeParam }}', {{ has_access ? 'true' : 'false' }})">
                    <div class="pdf-option-plans">
                        {% if tool.plans is not empty %}
                            <span class="plan-tag {{ tool.plans[0]|lower }}">{{ tool.plans[0] }}</span>
                        {% endif %}
                    </div>
                    <div class="pdf-option-icon">
                        {{ tool.logo|raw }}
                    </div>
                    <h3>{{ tool.name }}</h3>
                    <p class="pdf-option-description">{{ tool.description }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function loadTool(routeParam, hasAccess) {
            if (!hasAccess) {
                window.location.href = '{{ path('subscription_change') }}';
                return;
            }

            const pdfConverterRoutes = ['url', 'html_raw', 'markdown', 'docx', 'xlsx', 'image', 'merge', 'screenshot'];

            if (pdfConverterRoutes.includes(routeParam)) {
                window.location.href = '/pdf/generate/' + routeParam;
            } else {
                window.location.href = '/tool/' + routeParam;
            }
        }
    </script>
{% endblock %}
