{% extends 'base.html.twig' %}

{% block title %}PDF-GEN - Accueil{% endblock %}

{% block stylesheets %}
    <style>
        /* ... (tous les styles précédents restent les mêmes) ... */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        .progress-section {
            padding: 1.5rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.875rem;
            border-bottom: 1px solid #000000;
            flex-wrap: wrap;
            gap: 1.5rem;
        }

        .progress-bar-container {
            flex: 1;
            margin: 0 2.5rem;
            min-width: 250px;
        }

        .progress-text {
            margin-bottom: 0.5rem;
            white-space: nowrap;
            font-weight: 500;
            font-size: 0.813rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #4A5568;
        }

        .progress-bar {
            width: 100%;
            height: 10px;
            background-color: #E2E8F0;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.06);
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--dark-color) 0%, #1a1a1a 100%);
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        .plan-info {
            text-align: right;
            font-weight: 600;
            color: #2D3748;
        }

        .plan-info div:last-child {
            font-size: 0.75rem;
            font-weight: 400;
            color: #718096;
            margin-top: 0.25rem;
        }

        .content-container {
            text-align: center;
            padding: 3rem 2rem;
        }

        .main-title {
            font-size: 4rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.1;
        }

        .subtitle {
            font-size: 1.25rem;
            margin-bottom: 4rem;
            font-weight: 400;
            color: #4A5568;
            letter-spacing: 0.3px;
        }

        .pdf-options {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 2rem;
            margin-bottom: 4rem;
            padding: 0 2rem;
        }

        .pdf-option {
            position: relative;
            background: #FFFFFF;
            border-radius: 16px;
            padding: 2.5rem 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            border: 1px solid #EAEAEA;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }

        .pdf-option:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.07);
            border-color: #DDDDDD;
        }

        .pdf-option-icon {
            font-size: 28px;
            color: var(--dark-color);
            margin-bottom: 1.25rem;
        }

        .pdf-option h3 {
            margin: 0 0 0.5rem 0;
            font-size: 1.1rem;
            font-weight: 600;
            color: #2D3748;
        }

        .pdf-option-description {
            font-size: 0.9rem;
            color: #718096;
            line-height: 1.6;
        }

        .pdf-option-plans {
            position: absolute;
            top: 1rem;
            right: 1rem;
            display: flex;
            gap: 0.4rem;
        }

        .plan-badge {
            height: 10px;
            width: 10px;
            border-radius: 50%;
            border: none;
            padding: 0;
            text-indent: -9999px;
            overflow: hidden;
        }

        .plan-badge.starter { background-color: #F4E04D; }
        .plan-badge.pro { background-color: #FF6B6B; }
        .plan-badge.elite { background-color: #4ECDC4; }
        .plan-badge.legend { background-color: #C792EA; }

        #pdf-form-container {
            margin: 0 auto 4rem auto;
            max-width: 900px;
            background-color: transparent;
            padding: 0;
            min-height: 200px;
            position: relative;
        }

        .features {
            display: flex;
            justify-content: center;
            gap: 4rem;
            margin-top: 5rem;
            padding-bottom: 3rem;
            flex-wrap: wrap;
        }

        .feature {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.875rem;
            letter-spacing: 1px;
            color: #2D3748;
        }

        .feature-icon {
            width: 24px;
            height: 24px;
            stroke-width: 2.5;
        }

        .hidden { display: none; }

        .loader {
            border: 5px solid #E2E8F0;
            border-top: 5px solid var(--dark-color);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 0.8s linear infinite;
            margin: 3rem auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
{% endblock %}

{% block content %}
    {% if app.user and app.user.plan %}
        {% set plan = app.user.plan %}
        {% set generations_used = app.user.generationsUsed %}
        {% set generation_limit = plan.limitGeneration %}
        {% set progress_percentage = (generation_limit > 0) ? (generations_used / generation_limit) * 100 : 0 %}
        {% set generations_left = generation_limit - generations_used %}

        <div class="progress-section">
            <div class="progress-text">Générations disponibles</div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: {{ progress_percentage }}%;"></div>
                </div>
            </div>
            <div style="font-weight: 600; color: #2D3748;">{{ generations_left }} / {{ generation_limit }} restants</div>
            <div class="plan-info">
                <div>Plan actuel : {{ plan.name|upper }}</div>
                {# Vous pouvez ajouter une date de renouvellement si vous en avez une #}
            </div>
        </div>
    {% endif %}

    <div class="content-container">
        <h1 class="main-title">CONVERTISSEUR PDF</h1>
        <p class="subtitle">Convertissez et modifiez instantanément tout type de document !</p>

        <div id="pdf-form-container" class="hidden">
            <div id="form-content"></div>
        </div>

        <div class="pdf-options" id="options-container">
            {% for tool in tools %}
                <div class="pdf-option" id="tool-card-{{ tool.routeParam }}" onclick="loadForm('{{ tool.routeParam }}', this)">
                    <div class="pdf-option-plans">
                        {% for plan_name in tool.plans %}
                            <span class="plan-badge {{ plan_name }}">{{ plan_name }}</span>
                        {% endfor %}
                    </div>
                    <div class="pdf-option-icon">
                        {{ tool.logo|raw }}
                    </div>
                    <h3>{{ tool.name }}</h3>
                    <p class="pdf-option-description">{{ tool.description }}</p>
                </div>
            {% endfor %}
        </div>

        <div class="features">
            {# ... features ... #}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {# ... javascripts ... #}
{% endblock %}
