{% extends 'base.html.twig' %}

{% block title %}PDF-GEN - Accueil{% endblock %}

{% block stylesheets %}
    <style>
        .home-content-container {
            text-align: center;
            padding: 3rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .progress-section {
            padding: 1.5rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.875rem;
            border-bottom: 1px solid #000000;
            flex-wrap: wrap;
            gap: 1.5rem;
            background-color: var(--bg-color);
        }

        .progress-bar-container {
            flex: 1;
            margin: 0 2.5rem;
            min-width: 250px;
        }

        .progress-text {
            margin-bottom: 0.5rem;
            white-space: nowrap;
            font-weight: 500;
            font-size: 0.813rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-color);
        }

        .progress-bar {
            width: 100%;
            height: 10px;
            background-color: #E2E8F0;
            border-radius: 0;
            overflow: hidden;
            border: 2px solid var(--dark-color);
        }

        .progress-fill {
            height: 100%;
            background: var(--dark-color);
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .plan-info {
            text-align: right;
            font-weight: 600;
            color: var(--text-color);
        }

        .plan-info div:last-child {
            font-size: 0.75rem;
            font-weight: 400;
            color: var(--text-color);
            margin-top: 0.25rem;
        }

        .main-title {
            font-size: 4rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
            color: var(--dark-color);
            line-height: 1.1;
        }

        .subtitle {
            font-size: 1.25rem;
            margin-bottom: 2rem;
            font-weight: 400;
            color: var(--text-color);
            letter-spacing: 0.3px;
        }

        .tools-section-title {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 2rem;
            color: var(--dark-color);
        }

        .pdf-options {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 2rem;
            margin-bottom: 4rem;
            padding: 0 2rem;
        }

        .pdf-option {
            position: relative;
            background: #FFFFFF;
            border-radius: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            transition: all 0.2s ease;
            border: 3px solid var(--dark-color);
            box-shadow: 4px 4px 0 var(--dark-color);
            text-decoration: none;
            color: var(--text-color);
            aspect-ratio: 1 / 1;
            justify-content: center;
        }

        .pdf-option:hover {
            transform: translate(-2px, -2px);
            box-shadow: 8px 8px 0 var(--dark-color);
        }

        .pdf-option.disabled {
            background-color: #f9f9f9;
            cursor: not-allowed;
            color: #595959;
            border-color: #595959;
            box-shadow: 4px 4px 0 #595959;
        }

        .pdf-option.disabled:hover {
            transform: none;
            box-shadow: 4px 4px 0 #595959;
        }

        .pdf-option.disabled .pdf-option-icon,
        .pdf-option.disabled .pdf-option-description,
        .pdf-option.disabled h3 {
            color: #595959;
        }

        .pdf-option-icon {
            font-size: 28px;
            color: var(--dark-color);
            margin-bottom: 1.25rem;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pdf-option h3 {
            margin: 0 0 0.5rem 0;
            font-size: 1.1rem;
            font-weight: 600;
        }

        .pdf-option-description {
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .pdf-option-plans {
            position: absolute;
            top: 1rem;
            right: 1rem;
            display: flex;
            gap: 0.4rem;
        }

        .plan-tag {
            padding: 0.25rem 0.5rem;
            font-size: 0.80rem;
            font-weight: 800;
            border: 2px solid black;
            text-transform: uppercase;
            color: #000;
        }

        .plan-tag.starter { background-color: #F4E04D; }
        .plan-tag.pro { background-color: #FF6B6B; }
        .plan-tag.elite { background-color: #4ECDC4; }
        .plan-tag.legend { background-color: #C792EA; }
    </style>
{% endblock %}

{% block body %}
    {% if app.user and app.user.plan %}
        <div class="progress-section">
            <div class="progress-text">Générations disponibles</div>
            {% if app.user.plan.limitGeneration == -1 %}
                <div style="font-weight: 600; color: #2D3748; flex-grow: 1; text-align: center;">Illimité</div>
            {% else %}
                <div class="progress-bar-container">
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{ ((app.user.generationsUsed / app.user.plan.limitGeneration) * 100)|round }}%;"></div>
                    </div>
                </div>
                <div style="font-weight: 600; color: #2D3748;">{{ app.user.plan.limitGeneration - app.user.generationsUsed }} / {{ app.user.plan.limitGeneration }} restants</div>
            {% endif %}
            <div class="plan-info">
                <div>Plan actuel : {{ app.user.plan.name|upper }}</div>
            </div>
        </div>
    {% endif %}

    <div class="home-content-container">
        <h1 class="main-title">CONVERTISSEUR PDF</h1>
        <p class="subtitle">Convertissez et modifiez instantanément tout type de document !</p>

        <h2 class="tools-section-title">Nos Outils</h2>
        <div class="pdf-options" id="options-container">
            {% for tool in tools %}
                {% set has_access = app.user and can_user_use_tool(app.user, tool) %}
                {% set tool_path = has_access ? path('app_tool_show', {'routeParam': tool.routeParam}) : path('subscription_change') %}

                <a href="{{ tool_path }}" class="pdf-option {% if not has_access %}disabled{% endif %}" id="tool-card-{{ tool.routeParam }}">
                    <div class="pdf-option-plans">
                        {% if tool.plans is not empty %}
                            <span class="plan-tag {{ tool.plans[0]|lower }}">{{ tool.plans[0] }}</span>
                        {% endif %}
                    </div>
                    <div class="pdf-option-icon">
                        {{ tool.logo|raw }}
                    </div>
                    <h3>{{ tool.name }}</h3>
                    <p class="pdf-option-description">{{ tool.description }}</p>
                </a>
            {% endfor %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}{% endblock %}
