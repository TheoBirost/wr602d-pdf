{% extends 'base.html.twig' %}

{% block title %}Contactez-nous{% endblock %}

{% block stylesheets %}
    <style>
        .contact-wrapper {
            display: flex;
            min-height: calc(100vh - 75px);
        }
        .contact-left {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5e6c8;
            padding: 2rem;
        }
        .contact-left img {
            max-width: 100%;
            height: auto;
        }
        .contact-right {
            flex: 1;
            background: #E8D4B8; /* COULEUR MISE A JOUR */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .contact-card {
            width: 100%;
            max-width: 420px;
            background: transparent;
        }
        .contact-card h1 {
            background: #1a1a1a;
            color: #fff;
            text-align: center;
            padding: 1rem;
            margin: 0 0 1.5rem 0;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        .form-group { margin-bottom: 1rem; }
        label { display: none; }
        input[type="text"], input[type="email"], textarea {
            width: 100%;
            padding: 0.75rem;
            background: #d9d9d9;
            border: none;
            border-radius: 4px;
            font-size: 0.95rem;
            box-sizing: border-box;
            color: #333;
            font-family: inherit;
        }
        input::placeholder, textarea::placeholder { color: #666; }
        .btn-submit { width: 100%; padding: 0.85rem; background: #1a1a1a; color: #fff; border: none; font-weight: 800; font-size: 1rem; letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer; margin-top: 0.5rem; border-radius: 3px; transition: background 0.2s; }
        .btn-submit:hover { background: #333; }
    </style>
{% endblock %}

{% block body %}
    <div class="contact-wrapper">
        <div class="contact-left">
            <img src="{{ asset('images/welcome-illustration.png') }}" alt="Contact illustration">
        </div>
        <div class="contact-right">
            <div class="contact-card">
                <h1>Contactez-nous</h1>
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="form-group">
                        {{ form_widget(form.name, {'attr': {'placeholder': 'Votre nom'}}) }}
                        {{ form_errors(form.name) }}
                    </div>
                    <div class="form-group">
                        {{ form_widget(form.email, {'attr': {'placeholder': 'Votre email'}}) }}
                        {{ form_errors(form.email) }}
                    </div>
                    <div class="form-group">
                        {{ form_widget(form.subject, {'attr': {'placeholder': 'Sujet'}}) }}
                        {{ form_errors(form.subject) }}
                    </div>
                    <div class="form-group">
                        {{ form_widget(form.message, {'attr': {'placeholder': 'Votre message...', 'rows': 5}}) }}
                        {{ form_errors(form.message) }}
                    </div>
                    <button type="submit" class="btn-submit">{{ form.submit.vars.label }}</button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
