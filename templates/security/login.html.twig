{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block content %}
    <div class="auth-container">
        <div class="auth-form-card">
            <h1>Connexion</h1>

            {% for message in app.flashes('success') %}
                <div style="color: green; margin-bottom: 1rem;">
                    {{ message }}
                </div>
            {% endfor %}

            {% if error %}
                <div class="error-message">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form action="{{ path('app_login_check') }}" method="post">
                <label for="username">Email</label>
                <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus>

                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="_password" required>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn btn-primary">Se connecter</button>
            </form>
        </div>
    </div>
{% endblock %}
