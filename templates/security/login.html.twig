{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    <style>
        .auth-wrapper {
            display: flex;
            min-height: calc(100vh - 75px);
        }
        .auth-left {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5e6c8;
            padding: 2rem;
        }
        .auth-left img {
            max-width: 100%;
            height: auto;
        }
        .auth-right {
            flex: 1;
            background: #E8D4B8; /* COULEUR MISE A JOUR */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .auth-card {
            width: 100%;
            max-width: 420px;
            background: transparent;
        }
        .auth-card h1 {
            background: #1a1a1a;
            color: #fff;
            text-align: center;
            padding: 1rem;
            margin: 0 0 1.5rem 0;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        .form-group { margin-bottom: 1rem; }
        label { display: none; }
        input[type="email"], input[type="password"] {
            width: 100%;
            padding: 0.75rem;
            background: #d9d9d9;
            border: none;
            border-radius: 4px;
            font-size: 0.95rem;
            box-sizing: border-box;
            color: #333;
        }
        input::placeholder { color: #666; }
        .btn-submit { width: 100%; padding: 0.85rem; background: #1a1a1a; color: #fff; border: none; font-weight: 800; font-size: 1rem; letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer; margin-top: 0.5rem; border-radius: 3px; transition: background 0.2s; }
        .btn-submit:hover { background: #333; }
        .auth-links { text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: #444; }
        .auth-links a { color: #1a1a1a; font-weight: 700; text-decoration: none; }
        .auth-links a:hover { text-decoration: underline; }
        .error-message { color: #c0392b; font-size: 0.9rem; margin-bottom: 1rem; text-align: center; background: #f8d7da; padding: 0.5rem; border-radius: 4px; }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-wrapper">
        <div class="auth-left">
            <img src="{{ asset('images/welcome-illustration.png') }}" alt="Welcome illustration">
        </div>
        <div class="auth-right">
            <div class="auth-card">
                <h1>Connexion</h1>
                {% if error %}
                    <div class="error-message">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}
                <form action="{{ path('app_login_check') }}" method="post">
                    <div class="form-group">
                        <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus placeholder="Adresse email">
                    </div>
                    <div class="form-group">
                        <input type="password" id="password" name="_password" required placeholder="Mot de passe">
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn-submit">Se connecter</button>
                </form>
                <div class="auth-links">
                    <p>Pas encore de compte ? <a href="{{ path('app_register') }}">Inscrivez-vous</a></p>
                    <p><a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a></p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
