{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<style>
    .login-container {
        display: flex;
        height: 100vh;
    }
    .login-image {
        flex: 1;
        background-color: var(--dark-color); /* Black background for image area */
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-color); /* Cream text for image area */
    }
    .login-form-container {
        flex: 1;
        padding: 4rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background-color: var(--bg-color); /* Cream background for form */
    }
    .nav-links {
        margin-bottom: 2rem;
        text-align: right;
    }
    .nav-links a {
        margin-left: 1rem;
        font-weight: 500; /* Medium */
        color: var(--text-color);
    }
    .login-form-container h1 {
        font-weight: 700; /* Bold */
        color: var(--text-color);
    }
    .register-link {
        margin-top: 1.5rem;
        text-align: center;
        font-weight: 400; /* Regular */
        color: var(--text-color);
    }
    .register-link a {
        font-weight: 600; /* Semi-bold */
        text-decoration: underline;
        color: var(--text-color);
    }
    .alert-danger {
        color: red; /* Keep red for error messages */
        margin-bottom: 1rem;
    }
</style>

<div class="login-container">
    <div class="login-image">
        <!-- Replace with your actual image -->
        <img src="https://via.placeholder.com/600x800/000000/FDE9BF?text=Your+Logo" alt="Login Image" style="max-width: 80%; height: auto;">
    </div>
    <div class="login-form-container">
        <div class="nav-links">
            <a href="{{ path('homepage') }}">Accueil</a>
            <a href="{{ path('history') }}">Historique</a>
            <a href="{{ path('subscription_change') }}">Plan</a>
        </div>

        <form method="post">
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3">
                    You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Logout</a>
                </div>
            {% endif %}

            <h1>Please sign in</h1>
            <label for="inputEmail">Email</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
            <label for="inputPassword">Password</label>
            <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>

            <input type="hidden" name="_csrf_token"
                   value="{{ csrf_token('authenticate') }}"
            >

            <button class="btn btn-lg btn-primary mt-3" type="submit" style="width: 100%;">
                Sign in
            </button>

            <p class="register-link">
                Pas de compte? <a href="{{ path('app_register') }}">Inscrivez-vous</a>
            </p>
        </form>
    </div>
</div>
{% endblock %}
