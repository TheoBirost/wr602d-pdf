{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block content %}
<div class="auth-container">
    <div class="auth-form-card" style="max-width: 600px; text-align: left;">
        <h1 style="text-align: center;">Mon Profil</h1>

        <div style="margin-bottom: 2rem;">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                {% if app.user.photo %}
                    <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="Photo de profil" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;">
                {% else %}
                    <div style="width: 80px; height: 80px; border-radius: 50%; background-color: #eee; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                        {% if app.user.firstname and app.user.lastname %}
                            {{ app.user.firstname|first|upper }}{{ app.user.lastname|first|upper }}
                        {% else %}
                            {{ app.user.email|first|upper }}
                        {% endif %}
                    </div>
                {% endif %}
                <div>
                    <h2 style="margin: 0; font-size: 1.5rem;">
                        {% if app.user.firstname and app.user.lastname %}
                            {{ app.user.firstname }} {{ app.user.lastname }}
                        {% else %}
                            {{ app.user.email }}
                        {% endif %}
                    </h2>
                    <p style="margin: 0.2rem 0 0; color: #666;">{{ app.user.email }}</p>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div>
                    <label style="display: block; font-weight: 600; margin-bottom: 0.2rem; color: #666;">Date de naissance</label>
                    <div>{{ app.user.dob ? app.user.dob|date('d/m/Y') : 'Non renseignée' }}</div>
                </div>
                <div>
                    <label style="display: block; font-weight: 600; margin-bottom: 0.2rem; color: #666;">Téléphone</label>
                    <div>{{ app.user.phone|default('Non renseigné') }}</div>
                </div>
                <div>
                    <label style="display: block; font-weight: 600; margin-bottom: 0.2rem; color: #666;">Couleur préférée</label>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        {% if app.user.favoriteColor %}
                            <span style="display: inline-block; width: 20px; height: 20px; background-color: {{ app.user.favoriteColor }}; border: 1px solid #ddd; border-radius: 4px;"></span>
                            {{ app.user.favoriteColor }}
                        {% else %}
                            Non renseignée
                        {% endif %}
                    </div>
                </div>
                <div>
                    <label style="display: block; font-weight: 600; margin-bottom: 0.2rem; color: #666;">Plan actuel</label>
                    <div>
                        {% if app.user.plan %}
                            <span style="background-color: var(--dark-color); color: white; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.85rem;">{{ app.user.plan.name|capitalize }}</span>
                        {% else %}
                            Aucun plan
                        {% endif %}
                    </div>
                </div>
                <div>
                    <label style="display: block; font-weight: 600; margin-bottom: 0.2rem; color: #666;">Statut du compte</label>
                    <div>
                        {% if app.user.isVerified %}
                            <span style="color: green; font-weight: 600;">✓ Vérifié</span>
                        {% else %}
                            <span style="color: orange; font-weight: 600;">⚠ Non vérifié</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div style="text-align: center; margin-top: 2rem;">
            <a href="#" class="btn btn-outline">Modifier mes informations</a>
        </div>
    </div>
</div>
{% endblock %}
