{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block stylesheets %}
    <style>
        .profile-wrapper {
            display: flex;
            min-height: calc(100vh - 75px);
        }
        .profile-left {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5e6c8;
            padding: 2rem;
        }
        .profile-left img {
            max-width: 100%;
            height: auto;
        }
        .profile-right {
            flex: 1;
            background: #E8D4B8; /* COULEUR MISE A JOUR */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .profile-card {
            width: 100%;
            max-width: 450px;
            background: transparent;
        }
        .profile-card h1 {
            background: #1a1a1a;
            color: #fff;
            text-align: center;
            padding: 1rem;
            margin: 0 0 1.5rem 0;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        .profile-avatar-container { text-align: center; margin-bottom: 1.5rem; }
        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background-color: #d9d9d9;
            color: #1a1a1a;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: 700;
            object-fit: cover;
            border: 4px solid #1a1a1a;
        }
        .profile-details { background-color: #d9d9d9; padding: 1.5rem; border-radius: 4px; }
        .detail-row { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #c9c9c9; }
        .detail-row:last-child { border-bottom: none; }
        .detail-label { font-weight: 700; color: #444; }
        .detail-value { font-weight: 500; color: #1a1a1a; }
        .plan-badge { background-color: #1a1a1a; color: white; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.85rem; }
        .status-badge.verified { color: #27ae60; font-weight: 700; }
        .status-badge.not-verified { color: #e67e22; font-weight: 700; }
        .btn-edit { display: inline-block; width: 94%; padding: 0.85rem; background: #1a1a1a; color: #fff; border: none; font-weight: 800; font-size: 1rem; letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer; margin-top: 1.5rem; border-radius: 3px; transition: background 0.2s; text-align: center; text-decoration: none; }
        .btn-edit:hover { background: #333; }
    </style>
{% endblock %}

{% block body %}
    <div class="profile-wrapper">
        <div class="profile-left">
            <img src="{{ asset('images/welcome-illustration.png') }}" alt="Profile illustration">
        </div>
        <div class="profile-right">
            <div class="profile-card">
                <h1>Mon Profil</h1>
                <div class="profile-avatar-container">
                    {% if app.user.photo %}
                        <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="Photo de profil" class="profile-avatar">
                    {% else %}
                        <div class="profile-avatar">
                            {{ app.user.firstname|first|upper }}{{ app.user.lastname|first|upper }}
                        </div>
                    {% endif %}
                </div>
                <div class="profile-details">
                    <div class="detail-row">
                        <span class="detail-label">Nom</span>
                        <span class="detail-value">{{ app.user.firstname }} {{ app.user.lastname }}</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Email</span>
                        <span class="detail-value">{{ app.user.email }}</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Plan Actuel</span>
                        <span class="detail-value">
                            {% if app.user.plan %}
                                <span class="plan-badge">{{ app.user.plan.name|capitalize }}</span>
                            {% else %}
                                Aucun plan
                            {% endif %}
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Statut</span>
                        <span class="detail-value">
                            {% if app.user.isVerified %}
                                <span class="status-badge verified">✓ Vérifié</span>
                            {% else %}
                                <span class="status-badge not-verified">⚠ Non vérifié</span>
                            {% endif %}
                        </span>
                    </div>
                </div>
                <a href="#" class="btn-edit">Modifier</a>
            </div>
        </div>
    </div>
{% endblock %}
