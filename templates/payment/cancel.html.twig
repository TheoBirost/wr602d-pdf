{% extends 'base.html.twig' %}

{% block title %}Paiement Annulé - PDF-GEN{% endblock %}

{% block stylesheets %}
    <style>
        .result-container {
            max-width: 800px;
            margin: 4rem auto;
            padding: 3rem;
            text-align: center;
            border: 3px solid #000000;
            background-color: #FFFFFF;
        }

        .result-icon {
            font-size: 4rem;
            color: #F44336; /* Rouge pour l'annulation/erreur */
            margin-bottom: 1.5rem;
        }

        .result-title {
            font-size: 2.5rem;
            font-weight: 900;
            margin: 0 0 1rem 0;
            color: #000000;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .result-message {
            font-size: 1.1rem;
            color: #4A5568;
            margin-bottom: 2.5rem;
            line-height: 1.6;
        }

        .btn-styled {
            display: inline-block;
            padding: 1rem 2rem;
            border-radius: 0;
            font-weight: 900;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s ease;
            border: 3px solid #000000;
            cursor: pointer;
            font-size: 1rem;
            letter-spacing: 1px;
            background-color: #FFFFFF;
            color: #000000;
        }

        .btn-styled:hover {
            background-color: #000000;
            color: #FFFFFF;
        }
    </style>
{% endblock %}

{% block body %}
<div class="result-container">
    <div class="result-icon">
        <i class="fa-solid fa-times-circle"></i>
    </div>
    <h1 class="result-title">Paiement Annulé</h1>
    <p class="result-message">
        Le processus de paiement a été annulé. Aucun montant n'a été débité. <br>
        N'hésitez pas à choisir un autre plan si vous changez d'avis.
    </p>
    <a href="{{ path('subscription_change') }}" class="btn-styled">Voir les plans</a>
</div>
{% endblock %}
