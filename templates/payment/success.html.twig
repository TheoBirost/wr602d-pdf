{% extends 'base.html.twig' %}

{% block title %}Paiement Réussi - PDF-GEN{% endblock %}

{% block stylesheets %}
    <style>
        .result-container {
            max-width: 800px;
            margin: 4rem auto;
            padding: 3rem;
            text-align: center;
            border: 3px solid #000000;
            background-color: #FFFFFF;
        }

        .result-icon {
            font-size: 4rem;
            color: #4CAF50; /* Vert pour le succès */
            margin-bottom: 1.5rem;
        }

        .result-title {
            font-size: 2.5rem;
            font-weight: 900;
            margin: 0 0 1rem 0;
            color: #000000;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .result-message {
            font-size: 1.1rem;
            color: #4A5568;
            margin-bottom: 2.5rem;
            line-height: 1.6;
        }

        .btn-styled {
            display: inline-block;
            padding: 1rem 2rem;
            border-radius: 0;
            font-weight: 900;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s ease;
            border: 3px solid #000000;
            cursor: pointer;
            font-size: 1rem;
            letter-spacing: 1px;
            background-color: #000000;
            color: #FFFFFF;
        }

        .btn-styled:hover {
            background-color: #FFFFFF;
            color: #000000;
        }
    </style>
{% endblock %}

{% block body %}
<div class="result-container">
    <div class="result-icon">
        <i class="fa-solid fa-check-circle"></i>
    </div>
    <h1 class="result-title">Paiement Réussi !</h1>
    <p class="result-message">
        Merci pour votre confiance. Votre abonnement a été mis à jour. <br>
        Vous allez être redirigé vers l'accueil dans quelques secondes.
    </p>
    <a href="{{ path('homepage') }}" class="btn-styled">Retour à l'accueil</a>
</div>

<script>
    setTimeout(function() {
        window.location.href = "{{ path('homepage') }}";
    }, 5000);
</script>
{% endblock %}
