{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
    <style>
        .register-wrapper {
            display: flex;
            min-height: calc(100vh - 75px); /* Hauteur de la navbar */
        }
        .register-left {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5e6c8;
            padding: 2rem;
        }
        .register-left img {
            max-width: 100%;
            height: auto;
        }
        .register-right {
            flex: 1;
            background: #E8D4B8; /* COULEUR MISE A JOUR */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .register-card {
            width: 100%;
            max-width: 420px;
            background: transparent; /* Fond de la carte transparent */
        }
        .register-card h1 {
            background: #1a1a1a;
            color: #fff;
            text-align: center;
            padding: 1rem;
            margin: 0 0 1.5rem 0;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        .form-group { margin-bottom: 0.75rem; }
        .form-row-inline { display: flex; gap: 0.75rem; margin-bottom: 0.75rem; }
        .form-row-inline > div { flex: 1; }
        label { display: none; }
        input[type="text"], input[type="email"], input[type="password"], input[type="tel"], input[type="date"], input[type="color"], input[type="file"] {
            width: 100%;
            padding: 0.75rem;
            background: #d9d9d9;
            border: none;
            border-radius: 4px;
            font-size: 0.95rem;
            box-sizing: border-box;
            color: #333;
        }
        input::placeholder { color: #666; }
        input[type="color"] { height: 42px; padding: 4px; }
        .form-agree-terms { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.2rem; font-size: 0.85rem; }
        .form-agree-terms a { color: #1a1a1a; text-decoration: underline; }
        .btn-submit { width: 100%; padding: 0.85rem; background: #1a1a1a; color: #fff; border: none; font-weight: 800; font-size: 1rem; letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer; margin-top: 0.5rem; border-radius: 3px; transition: background 0.2s; }
        .btn-submit:hover { background: #333; }
        .login-link { text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: #444; }
        .login-link a { color: #1a1a1a; font-weight: 700; text-decoration: none; }
        .login-link a:hover { text-decoration: underline; }
        .form-error { color: #c0392b; font-size: 0.8rem; margin-top: 0.2rem; text-align: left; }
    </style>
{% endblock %}

{% block body %}
    <div class="register-wrapper">
        <div class="register-left">
            <img src="{{ asset('images/welcome-illustration.png') }}" alt="Welcome illustration">
        </div>
        <div class="register-right">
            <div class="register-card">
                <h1>Inscription</h1>
                {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="form-row-inline">
                        <div>
                            {{ form_widget(registrationForm.firstname, {'attr': {'placeholder': 'Prénom'}}) }}
                            <div class="form-error">{{ form_errors(registrationForm.firstname) }}</div>
                        </div>
                        <div>
                            {{ form_widget(registrationForm.lastname, {'attr': {'placeholder': 'Nom'}}) }}
                            <div class="form-error">{{ form_errors(registrationForm.lastname) }}</div>
                        </div>
                    </div>
                    <div class="form-group">
                        {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'Adresse email'}}) }}
                        <div class="form-error">{{ form_errors(registrationForm.email) }}</div>
                    </div>
                    <div class="form-group">
                        {{ form_widget(registrationForm.plainPassword, {'attr': {'placeholder': 'Mot de passe'}}) }}
                        <div class="form-error">{{ form_errors(registrationForm.plainPassword) }}</div>
                    </div>
                    <div class="form-row-inline">
                        <div>
                            {{ form_widget(registrationForm.phone, {'attr': {'placeholder': 'Téléphone (optionnel)'}}) }}
                            <div class="form-error">{{ form_errors(registrationForm.phone) }}</div>
                        </div>
                        <div>
                            {{ form_widget(registrationForm.dob, {'attr': {'placeholder': 'Date de naissance'}}) }}
                            <div class="form-error">{{ form_errors(registrationForm.dob) }}</div>
                        </div>
                    </div>
                    <div class="form-group">
                        {{ form_widget(registrationForm.favoriteColor, {'attr': {'title': 'Couleur favorite'}}) }}
                        <div class="form-error">{{ form_errors(registrationForm.favoriteColor) }}</div>
                    </div>
                    <div class="form-group">
                        {{ form_widget(registrationForm.photo) }}
                        <div class="form-error">{{ form_errors(registrationForm.photo) }}</div>
                    </div>
                    <div class="form-agree-terms">
                        {{ form_widget(registrationForm.agreeTerms) }}
                        <label for="{{ registrationForm.agreeTerms.vars.id }}">J'accepte les <a href="#">termes et conditions</a></label>
                    </div>
                    <div class="form-error" style="margin-top: -1rem; margin-bottom: 1rem;">{{ form_errors(registrationForm.agreeTerms) }}</div>
                    <button type="submit" class="btn-submit">Créer mon compte</button>
                {{ form_end(registrationForm) }}
                <div class="login-link">
                    Déjà un compte ? <a href="{{ path('app_login') }}">Connectez-vous</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
