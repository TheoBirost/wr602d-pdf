{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
    <div class="auth-container">
        <div class="auth-form-card">
            <h1>Inscription</h1>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}
                <label for="registration_form_firstname">Prénom</label>
                {{ form_widget(registrationForm.firstname, {'attr': {'placeholder': 'Votre prénom'}}) }}
                {{ form_errors(registrationForm.firstname) }}

                <label for="registration_form_lastname">Nom de famille</label>
                {{ form_widget(registrationForm.lastname, {'attr': {'placeholder': 'Votre nom de famille'}}) }}
                {{ form_errors(registrationForm.lastname) }}

                <label for="registration_form_email">Email</label>
                {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'Votre adresse email'}}) }}
                {{ form_errors(registrationForm.email) }}

                <label for="registration_form_plainPassword">Mot de passe</label>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'placeholder': 'Votre mot de passe'}}) }}
                {{ form_errors(registrationForm.plainPassword) }}

                <div style="text-align: left; margin-bottom: 1.5rem;">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    <label for="registration_form_agreeTerms" style="display: inline; margin-left: 0.5rem; font-weight: normal;">
                        Accepter les termes
                    </label>
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="btn btn-primary">S'inscrire</button>
            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}