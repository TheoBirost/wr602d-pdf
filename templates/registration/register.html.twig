{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block content %}
    <div class="auth-container">
        <div class="auth-form-card">
            <h1>Inscription</h1>

            {{ form_start(registrationForm) }}
                <div style="margin-bottom: 1rem;">
                    {{ form_label(registrationForm.firstname, 'Prénom') }}
                    {{ form_widget(registrationForm.firstname, {'attr': {'placeholder': 'Votre prénom', 'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.firstname) }}
                </div>

                <div style="margin-bottom: 1rem;">
                    {{ form_label(registrationForm.lastname, 'Nom de famille') }}
                    {{ form_widget(registrationForm.lastname, {'attr': {'placeholder': 'Votre nom de famille', 'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.lastname) }}
                </div>

                <div style="margin-bottom: 1rem;">
                    {{ form_label(registrationForm.email, 'Email') }}
                    {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'Votre adresse email', 'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div style="margin-bottom: 1rem;">
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe') }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'placeholder': 'Votre mot de passe', 'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                <div style="text-align: left; margin-bottom: 1.5rem;">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    <label for="{{ registrationForm.agreeTerms.vars.id }}" style="display: inline; margin-left: 0.5rem; font-weight: normal;">
                        Accepter les termes
                    </label>
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;">S'inscrire</button>
            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}