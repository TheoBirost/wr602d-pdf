{% extends 'base.html.twig' %}

{% block title %}PDF Preview{% endblock %}

{% block body %}
    <h1>PDF Preview</h1>

    <div class="mb-3">
        <embed src="data:application/pdf;base64,{{ pdf_data }}" type="application/pdf" width="100%" height="600px" />
    </div>

    <a href="{{ path('pdf_download', {'url': original_url}) }}" class="btn btn-primary">
        Download PDF
    </a>
    <a href="{{ path('pdf_generate') }}" class="btn btn-secondary">
        Generate another
    </a>
{% endblock %}
